# ============================================
# 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# .env 文件不会被上传到 Git（已在 .gitignore 中排除）
# ============================================

# --- LLM 配置 ---
# DeepSeek 示例
LLM_API_KEY=sk-your-llm-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# --- Embedding 配置 ---
# 后端: "local"（本地免费模型）或 "openai"（API 调用）

# === 方案A: 本地模型（推荐，免费免 Key）===
EMBEDDING_PROVIDER=local
# bge-small-zh-v1.5: 24MB, 快速, 中文效果好
# bge-large-zh-v1.5: 326MB, 最佳中文检索质量
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# === 方案B: API 调用（按需切换）===
# 把上面 EMBEDDING_PROVIDER 改成 "openai"，并填入以下配置
# Google Gemini 示例:
# EMBEDDING_API_KEY=your-google-api-key
# EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# EMBEDDING_MODEL=text-embedding-004
# OpenAI 示例:
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# --- 文本切分参数 ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- 检索参数 ---
TOP_K=5

# --- 代理配置（VPN）---
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
