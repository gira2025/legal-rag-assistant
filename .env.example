# ============================================
# 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# .env 文件不会被上传到 Git（已在 .gitignore 中排除）
# ============================================

# OpenAI / 兼容 API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 向量数据库
CHROMA_PERSIST_DIR=./data/chroma_db

# 嵌入模型
EMBEDDING_MODEL=text-embedding-3-small
